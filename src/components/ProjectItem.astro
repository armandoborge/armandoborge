---
import { Image } from 'astro:assets'

const { project, index } = Astro.props
const { name, subtitle, year, description, image, url } = project
const num = String(index + 1).padStart(2, '0')
---

<article
    class='group border-yang/10 last:border-yang/10 dark:border-yin/10 last:dark:border-yin/10 mx-auto max-w-4xl border-t last:border-b'
>
    <a
        href={url}
        target='_blank'
        rel='noopener noreferrer'
        class='group-hover:bg-yang/2.5 dark:group-hover:bg-yin/2.5 relative flex flex-col px-4 py-6 transition-colors duration-300 sm:flex-row sm:items-center sm:gap-6 sm:py-10 sm:pr-4 sm:pl-6'
    >
        <!-- Image block: full-width on mobile (top), fixed-size column on desktop (right) -->
        <div class='order-first mb-4 flex shrink-0 flex-col items-end gap-3 sm:order-last sm:mb-0'>
            <time class='text-ajna font-mono text-xs'>{num}</time>
            <div class='relative w-full sm:w-auto'>
                <!-- Ghost number -->
                <span
                    class='pointer-events-none absolute top-2 left-2 z-10 leading-none font-black text-white opacity-70 select-none sm:top-auto sm:bottom-2 sm:-left-14'
                    style='font-size: clamp(2rem, 2.5vw, 2rem);'
                    aria-hidden='true'>{year}</span
                >
                <div class='h-96 w-full overflow-hidden rounded sm:h-44 sm:w-40 md:h-52 md:w-56 lg:h-60 lg:w-72'>
                    <Image
                        src={image}
                        alt={name}
                        width='900'
                        height='900'
                        class='size-full object-cover transition-transform duration-500 group-hover:scale-125'
                    />
                </div>
            </div>
        </div>

        <!-- Main content -->
        <div class='min-w-0 flex-1'>
            <div class='mb-2 flex items-baseline gap-3'>
                <span class='text-yang/40 dark:text-yin/40 truncate text-[10px] tracking-[0.2em] uppercase'
                    >{subtitle}</span
                >
            </div>
            <h2
                class='group-hover:text-ajna text-4xl leading-[0.9] font-bold tracking-tight transition-colors duration-300 md:text-5xl lg:text-6xl'
            >
                {name}
            </h2>
            <p class='text-yang/55 dark:text-yin/55 mt-3 max-w-sm text-sm leading-relaxed'>
                {description}
            </p>
            <span class='text-ajna relative mt-2 inline-block w-fit text-sm font-medium transition-all duration-300'>
                {url} →
                <span class='bg-ajna absolute bottom-0 left-0 h-px w-0 transition-all duration-300 group-hover:w-full'
                ></span>
            </span>
        </div>
    </a>
</article>
