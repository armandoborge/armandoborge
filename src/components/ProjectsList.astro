---
import ProjectItem from '@/components/ProjectItem.astro'
import conconImage from '@/img/concon.jpg'
import notebookImage from '@/img/notebook.jpg'
import cactusImage from '@/img/cactus.jpg'
import asanaImage from '@/img/asana.jpg'
import jaguarImage from '@/img/jaguar.jpg'
import womanImage from '@/img/woman.jpg'
import yatchImage from '@/img/yatch.jpg'
import mexicoImage from '@/img/mx.jpg'
import contentImage from '@/img/content.jpg'

const projects = [
    {
        name: 'Content Seed',
        subtitle: 'AI Content Generation Tool',
        description:
            'An AI-powered content generator that creates carousels, stories, email sequences and content plans for creators and agencies.',
        year: 2026,
        url: 'https://contentseed.app',
        image: contentImage,
    },
    {
        name: 'Tribu Yoga',
        subtitle: 'SaaS Platform',
        description:
            'A wellness SaaS application designed to manage yoga studios, streamline class scheduling and support studio operations.',
        year: 2021,
        url: 'https://www.tribu.yoga',
        image: asanaImage,
    },
    {
        name: 'Melisa Redondo',
        subtitle: 'Designer & Brand Strategist Portfolio',
        description:
            'A custom multilingual portfolio and personal brand showcase for a creative professional with an international client base.',
        year: 2023,
        url: 'https://www.melisaredondo.com',
        image: cactusImage,
    },
    {
        name: 'Tripping Cats',
        subtitle: 'Minimal Landing Page',
        description: 'A responsive, ultra-minimalist landing page built for Tripping Cats OÜ online presence.',
        year: 2019,
        url: 'https://www.trippingcats.com',
        image: jaguarImage,
    },
    {
        name: 'Armando Borge',
        subtitle: 'Personal Portfolio',
        description: 'A minimalist, statically generated personal showcase featuring a modern design.',
        year: 2025,
        url: 'https://www.armandoborge.com',
        image: conconImage,
    },
    {
        name: 'Challenge Tracker',
        subtitle: 'Productivity Tool',
        description: 'A modern, minimalist, and private challenges and habits tracker.',
        year: 2026,
        url: 'https://challenge-tracker.armandoborge.com/',
        image: notebookImage,
    },
    {
        name: 'Travel Photo Log',
        subtitle: 'Photos Gallery App',
        description: "A travel journal app to record travel memories right as they're happening.",
        year: 2018,
        url: 'https://travels.armandoborge.com',
        image: mexicoImage,
    },
    {
        name: 'La Candidieta',
        subtitle: 'Health & Wellness App',
        description:
            'A health app designed to help women recover from Candidiasis through guided nutrition, practical recipes, and sustainable lifestyle tips.',
        year: 2018,
        url: 'https://lacandidieta.netlify.app',
        image: womanImage,
    },
    {
        name: 'Capitall',
        subtitle: 'SaaS Platform',
        description:
            'A personal finance SaaS platform that helps users set financial goals, track expenses, receive payment reminders, and gain financial education.',
        year: 2020,
        url: 'https://capitallapp.netlify.app/',
        image: yatchImage,
    },
]
---

<section>
    <div class='mx-auto mb-4 flex max-w-4xl items-center gap-4'>
        <span class='bg-yang/10 dark:bg-yin/10 h-px flex-1'></span>
        <span class='text-ajna text-[10px] font-medium tracking-[0.3em] uppercase'>Selected Work</span>
        <span class='bg-yang/10 dark:bg-yin/10 h-px flex-1'></span>
    </div>
    <div>
        {projects.map((project, index) => <ProjectItem project={project} index={index} />)}
    </div>
</section>
